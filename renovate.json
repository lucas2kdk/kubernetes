{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":dependencyDashboard",
    ":semanticCommits"
  ],
  "timezone": "Europe/Copenhagen",
  "schedule": ["before 7am on monday"],
  "labels": ["dependencies", "renovate"],
  "prHourlyLimit": 4,
  "prConcurrentLimit": 10,
  "flux": {
    "managerFilePatterns": [
      "/(^|/).+\\.ya?ml$/"
    ]
  },
  "helm-values": {
    "managerFilePatterns": [
      "/(^|/).+\\.ya?ml$/"
    ]
  },
  "customManagers": [
    {
      "customType": "regex",
      "description": "Headlamp plugins fetched at runtime by the chart pluginsManager (configContent). Tracked against the headlamp-k8s/plugins repo, where each plugin is tagged '<name>-<version>' (e.g. flux-0.6.0).",
      "managerFilePatterns": [
        "/^platform/base/headlamp/release\\.yaml$/"
      ],
      "matchStrings": [
        "- name: (?<depName>\\S+)\\s+source: \\S+headlamp-plugins\\S*\\s+version: (?<currentValue>\\S+)"
      ],
      "datasourceTemplate": "github-tags",
      "packageNameTemplate": "headlamp-k8s/plugins",
      "extractVersionTemplate": "^{{{depName}}}-(?<version>.+)$",
      "versioningTemplate": "semver-coerced"
    }
  ],
  "packageRules": [
    {
      "description": "Group Kyverno chart and Policy Reporter updates",
      "matchPackageNames": ["kyverno", "policy-reporter"],
      "groupName": "kyverno stack"
    },
    {
      "description": "Group Flux GitOps toolkit component bumps",
      "matchManagers": ["flux"],
      "matchDepNames": ["fluxcd/flux2"],
      "groupName": "flux"
    },
    {
      "description": "Require manual approval for major version bumps",
      "matchUpdateTypes": ["major"],
      "dependencyDashboardApproval": true
    }
  ]
}
